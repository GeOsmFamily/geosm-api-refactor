# Application
NODE_ENV=development
APP_PORT=3005
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1
APP_NAME=GeOSM API
APP_URL=http://localhost:3000

# Domaine public de base, utilise UNIQUEMENT en production pour construire les URL externes
# de Grafana/Graylog (https://grafana.PUBLIC_DOMAIN, https://graylog.PUBLIC_DOMAIN) - voir
# docs/deploiement.md, section "Sous-domaines pour les outils d'observabilite". Sans effet en
# dev (docker-compose.yml de base ne le lit pas).
PUBLIC_DOMAIN=geosm.app

# ============================================================================
# Ports publies sur l'hote (docker-compose.yml / docker-compose.prod.yml)
# ============================================================================
# Chaque variable ci-dessous controle UNIQUEMENT le port cote HOTE (le port a gauche du ":"
# dans "ports:") - le port interne au reseau Docker (a droite du ":") reste toujours fixe et
# n'a pas besoin de changer, le reste de la stack continue de se parler par nom de service
# (ex. "postgres:5432") quel que soit le port publie ici. A modifier UNIQUEMENT si un port
# est deja pris par un autre service sur le meme serveur (frequent sur un VPS mutualise).
# En production, tous ces ports (sauf FRONTEND_PORT) sont de toute facon lies a 127.0.0.1
# (non joignables depuis Internet, voir docker-compose.prod.yml) - remapper le NUMERO ne
# change pas leur niveau d'exposition.

# Port hote publie par le conteneur frontend (nginx) - LE SEUL de cette section a etre
# public en production. Derriere Apache/Nginx/Caddy, ce port ne doit PAS etre 80/443 (deja
# pris par le reverse proxy du systeme) - utiliser un port interne libre, ex. 8080, et faire
# pointer le vhost dessus. Voir docs/deploiement.md - section Reverse proxy et SSL.
FRONTEND_PORT=80

POSTGRES_PORT=5432
REDIS_HOST_PORT=6379
# MINIO_PUBLIC_PORT sert deux fois : le port publie sur l'hote ET le port utilise pour
# construire les URLs presignees renvoyees au navigateur (voir plus bas, section MinIO) -
# les deux doivent rester identiques, d'ou une seule variable pour les deux usages.
MINIO_CONSOLE_PORT=9001
MEILISEARCH_PORT=7700
QGIS_SERVER_PORT=8380
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
JAEGER_UI_PORT=16686
JAEGER_OTLP_PORT=4318
GRAYLOG_WEB_PORT=9009
GRAYLOG_GELF_PORT=12201
# Uniquement definis par docker-compose.prod.yml (Nominatim/OSRM auto-heberges, absents en dev)
NOMINATIM_PORT=8081
OSRM_PORT=5000

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql://geosm:geosm_secret@postgres:5432/geosm?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Argon2 Hashing
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# Rate Limiting
RATE_LIMIT_PUBLIC=10
RATE_LIMIT_AUTHENTICATED=100
RATE_LIMIT_ADMIN=1000
RATE_LIMIT_WINDOW_MS=60000

# SMTP (Email)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@geosm.org

# MinIO (S3-compatible Object Storage)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=geosm
MINIO_USE_SSL=false
# Hôte/port publics utilisés pour signer les URLs présignées ouvertes par le navigateur
# (MINIO_ENDPOINT="minio" n'est résolvable que dans le réseau Docker interne). MINIO_PUBLIC_PORT
# est aussi le port publié sur l'hôte par docker-compose (voir section "Ports publiés" plus haut)
# - IMPORTANT en production : ce port reste lié à 127.0.0.1 par défaut (docker-compose.prod.yml),
# donc ces URLs présignées ne sont PAS atteignables depuis un navigateur externe tant qu'aucune
# exposition publique (ouverture firewall, ou proxy dédié) n'est mise en place - voir la note
# correspondante dans docs/deploiement.md.
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PUBLIC_PORT=9000

# Meilisearch (Full-text Search)
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=geosm-meilisearch-dev-key-2026
# "production" desactive les logs verbeux et l'UI d'analytics de Meilisearch - a utiliser
# en prod (voir docker-compose.yml, service meilisearch)
MEILI_ENV=development

# QGIS Server
QGIS_SERVER_URL=http://qgis-server:8080/ows
QGIS_PROJECTS_DIR=/projects
QGIS_STYLES_DIR=/qgis-styles
DATA_DIR=/data
NOMINATIM_URL=http://localhost:8081
OSRM_URL=http://localhost:5000
# Requis uniquement en production par docker-compose.prod.yml (conteneur nominatim
# auto-heberge, Lot P9) - mot de passe du postgres interne a ce conteneur, sans rapport avec
# DATABASE_URL. Voir docs/deploiement.md - Auto-hebergement Nominatim et OSRM.
NOMINATIM_DB_PASSWORD=change-me-nominatim-db-password
# Import OSM programme (job mensuel) : chemin du .osm.pbf a reimporter periodiquement -
# non defini = le job tourne mais ne fait rien (voir docs/fonctionnalites-detaillees.md #29.10)
# OSM_IMPORT_PBF_PATH=/data/cameroon-latest.osm.pbf
OSM_IMPORT_CRON=0 2 1 * *

# Backup PostgreSQL programme (voir DatabaseBackupUseCase) - actif par defaut, ne depend
# d'aucune configuration externe. Format cron standard (5 champs).
BACKUP_CRON=0 3 * * *
BACKUP_RETENTION_DAYS=30

# Token public Mapbox (fond de carte "Mapbox Streets" cree par defaut pour chaque instance) -
# generer le votre sur https://account.mapbox.com/access-tokens/. Si absent, ce fond de carte
# est simplement omis de la liste proposee (pas de crash).
MAPBOX_ACCESS_TOKEN=

# Google Gemini (assistant IA agentique, requetes en langage naturel, etc.)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Auth OpenStreetMap (OAuth 2.0) - optionnel : le bouton "Se connecter avec OpenStreetMap" est
# masque cote frontend si absent. Enregistrer une app sur https://www.openstreetmap.org/oauth2/applications
# (ou le sandbox https://master.apis.dev.openstreetmap.org pour les tests) avec le scope read_prefs
# uniquement (les contributions OSM sont hors scope pour l'instant).
OSM_OAUTH_CLIENT_ID=
OSM_OAUTH_CLIENT_SECRET=
OSM_OAUTH_REDIRECT_URI=http://localhost:3005/api/v1/auth/osm/callback
OSM_OAUTH_BASE_URL=https://www.openstreetmap.org
# Cle de chiffrement (32 octets hex) du token OSM au repos - generer avec :
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Logging & Monitoring
LOG_LEVEL=info
PROMETHEUS_ENABLED=true

# Observability (all optional)
GRAYLOG_HOST=
GRAYLOG_PORT=12201
SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAME=geosm-api
GRAFANA_PASSWORD=admin
# Secrets internes au conteneur Graylog (voir docker-compose.yml, service graylog) - sans
# rapport avec GRAYLOG_HOST/PORT ci-dessus (qui configurent le CLIENT GELF cote API). Valeurs
# par defaut du template Graylog officiel, A CHANGER en production :
# - GRAYLOG_PASSWORD_SECRET : chaine aleatoire (min. 16 caracteres) : openssl rand -hex 32
# - GRAYLOG_ROOT_PASSWORD_SHA2 : SHA-256 du mot de passe admin Graylog :
#     echo -n 'VotreMotDePasse' | sha256sum
GRAYLOG_PASSWORD_SECRET=somepasswordpepper1234567890abcdef
GRAYLOG_ROOT_PASSWORD_SHA2=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918

# Super Admin (initial seed)
SUPER_ADMIN_EMAIL=admin@geosm.org
SUPER_ADMIN_PASSWORD=AdminP@ssw0rd!
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# CORS
CORS_ORIGIN=http://localhost:4200

# Docker Compose overrides
POSTGRES_PASSWORD=geosm_secret
