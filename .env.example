# Application
NODE_ENV=development
APP_PORT=3005
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1
APP_NAME=GeOSM API
APP_URL=http://localhost:3000

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql://geosm:geosm_secret@postgres:5432/geosm?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Argon2 Hashing
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# Rate Limiting
RATE_LIMIT_PUBLIC=10
RATE_LIMIT_AUTHENTICATED=100
RATE_LIMIT_ADMIN=1000
RATE_LIMIT_WINDOW_MS=60000

# SMTP (Email)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@geosm.org

# MinIO (S3-compatible Object Storage)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=geosm
MINIO_USE_SSL=false

# Meilisearch (Full-text Search)
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=geosm-meilisearch-dev-key-2026

# QGIS Server
QGIS_SERVER_URL=http://qgis-server:8080/ows
QGIS_PROJECTS_DIR=/projects
QGIS_STYLES_DIR=/qgis-styles
DATA_DIR=/data
NOMINATIM_URL=http://localhost:8081
OSRM_URL=http://localhost:5000
# Import OSM programme (job mensuel) : chemin du .osm.pbf a reimporter periodiquement -
# non defini = le job tourne mais ne fait rien (voir docs/fonctionnalites-detaillees.md #29.10)
# OSM_IMPORT_PBF_PATH=/data/cameroon-latest.osm.pbf
OSM_IMPORT_CRON=0 2 1 * *

# Logging & Monitoring
LOG_LEVEL=info
PROMETHEUS_ENABLED=true

# Observability (all optional)
GRAYLOG_HOST=
GRAYLOG_PORT=12201
SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAME=geosm-api
GRAFANA_PASSWORD=admin

# Super Admin (initial seed)
SUPER_ADMIN_EMAIL=admin@geosm.org
SUPER_ADMIN_PASSWORD=AdminP@ssw0rd!
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# CORS
CORS_ORIGIN=http://localhost:4200

# Docker Compose overrides
POSTGRES_PASSWORD=geosm_secret
