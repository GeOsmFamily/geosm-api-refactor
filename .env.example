# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1
APP_NAME=GeOSM API
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://geosm:geosm_secret@localhost:5432/geosm?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (RS256)
JWT_ACCESS_SECRET=your-access-secret-key
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Argon2
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# Rate Limiting
RATE_LIMIT_PUBLIC=10
RATE_LIMIT_AUTHENTICATED=100
RATE_LIMIT_ADMIN=1000
RATE_LIMIT_WINDOW_MS=60000

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@geosm.org

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio_access
MINIO_SECRET_KEY=minio_secret
MINIO_BUCKET=geosm
MINIO_USE_SSL=false

# MeiliSearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=masterKey

# QGIS Server
QGIS_SERVER_URL=http://localhost:8380/ows

# Nominatim
NOMINATIM_URL=http://localhost:8081

# OSRM
OSRM_URL=http://localhost:5000

# Observability
LOG_LEVEL=info
PROMETHEUS_ENABLED=true

# Super Admin Seed
SUPER_ADMIN_EMAIL=admin@geosm.org
SUPER_ADMIN_PASSWORD=AdminP@ssw0rd!
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# CORS
CORS_ORIGIN=http://localhost:4200
