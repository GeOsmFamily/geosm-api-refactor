    {
      "id": 14,
      "title": "Cible Prometheus \"jaeger\" up",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 41
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "up{job=\"jaeger\"}",
          "legendFormat": "Cible Prometheus \"jaeger\" up",
          "refId": "A"
