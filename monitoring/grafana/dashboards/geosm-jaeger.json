        {
          "expr": "histogram_quantile(0.99, sum(rate(jaeger_query_latency_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
